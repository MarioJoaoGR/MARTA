        ```
    
    """
    def __init__(self):
        self.renderfuncs = {}
        self.is_muted = False
        self.eightbit_call = lambda x: x
        self.rgb_call = lambda r, g, b: (r, g, b)

    def __call__(self, *args: Union[int, str], **kwargs) -> str:
        """
        This function is to handle calls such as `fg(42)`, `bg(102, 49, 42)`, and `fg('red')`. It returns an empty string if the object is muted. If there's one argument, it checks whether it's an 8-bit color code (int) or a named attribute (str), returning the corresponding value. If there are three arguments, it assumes they represent RGB values for a 24-bit color and returns the appropriate result.
