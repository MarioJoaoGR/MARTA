def _render_rules(
    renderfuncs: Renderfuncs,
    rules: Iterable[StylingRule],
) -> Tuple[str, Iterable[StylingRule]]:
    """
    Renders styling rules into a string and flattens the rules.

    This function processes a collection of StylingRules using provided render functions. It recursively handles nested Style rules by calling itself with updated parameters. The main purpose is to convert each rule into its rendered form and accumulate these forms into a single string, while also maintaining a flattened list of all processed rules.

    Parameters:
        renderfuncs (Renderfuncs): A dictionary-like object that maps types to rendering functions. Each function should accept the corresponding type's arguments.
        rules (Iterable[StylingRule]): An iterable containing StylingRules to be rendered. This can include nested Style rules which will be processed recursively.

    Returns:
        Tuple[str, Iterable[StylingRule]]: A tuple where the first element is a string of all rendered rules concatenated together, and the second element is an iterable of all processed rules including those that were nested within others.

    Raises:
        ValueError: If the 'rules' parameter is not an instance of Iterable[StylingRule].

    Examples:
        To use this function, you would typically call it with a dictionary of render functions and an iterable of styling rules like so:
        
        ```python
        from typing import Dict, Callable, List, Tuple, Iterable

        class StylingRule:
            pass

        class RenderType(StylingRule):
            def __init__(self, args: tuple):
                self.args = args

        class Style(StylingRule):
            def __init__(self, rules: List[StylingRule]):
                self.rules = rules

        renderfuncs = {RenderType: lambda *args: f"Rendered {args}"}
        rules = [RenderType((1, 2)), Style([RenderType((3, 4))])]
        
        rendered_text, flattened_rules = _render_rules(renderfuncs, rules)
        print(rendered_text)  # Output: "Rendered (1, 2)"
        for rule in flattened_rules:
            print(rule)  # Should show both RenderType instances and their nested structure
        ```

    This function is crucial for rendering complex styling rules within a system that supports dynamic content generation based on these rules. It ensures that all rules are processed correctly, including those nested within other rules, providing a flexible and extensible way to handle diverse styling requirements in applications where rule-based rendering is essential.
    """
```
"""
def _render_rules(
    renderfuncs: Renderfuncs,
    rules: Iterable[StylingRule],
) -> Tuple[str, Iterable[StylingRule]]:
    rendered: str = ""
    flattened_rules: List[StylingRule] = []

    for rule in rules:
        if isinstance(rule, RenderType):
            f1: Callable = renderfuncs[type(rule)]
            rendered += f1(*rule.args)
            flattened_rules.append(rule)

        elif isinstance(rule, Style):
            r1, r2 = _render_rules(renderfuncs, rule.rules)
            rendered += r1
            flattened_rules.extend(r2)

        else:
            raise ValueError("Parameter 'rules' must be of type Iterable[Rule].")

    return rendered, flattened_rules
                
