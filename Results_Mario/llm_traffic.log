class EfRegister:
    """
        A class for creating and managing text effects such as bold, italic, underline, blink, etc.
    
        This class provides instances that can be used to apply various text formatting options.
        
        Attributes:
            b (Style): Style object representing the bold effect.
            bold (Style): Alias for the bold effect.
            dim (Style): Style object representing the dim effect.
            i (Style): Style object representing the italic effect.
            italic (Style): Alias for the italic effect.
            u (Style): Style object representing the underline effect.
            underl (Style): Alias for the underline effect.
            blink (Style): Style object representing the blink effect.
            inverse (Style): Style object representing the inverse effect.
            hidden (Style): Style object representing the hidden effect.
            strike (Style): Style object representing the strike-through effect.
            rs (Style): Style object used to reset all effects, effectively clearing any applied text formatting.
        
        Examples:
            ef = EfRegister()
            print(f"{ef.bold}Bold Text{ef.rs}")  # Prints bold text followed by a reset of all effects.
