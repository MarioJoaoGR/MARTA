from register import EfRegister
import pytest

@pytest.fixture
def ef_register():
    return EfRegister()

def test_bold_effect(ef_register):
    assert str(ef_register.b) == "\x1b[1mBold Text\x1b[0m"
    assert str(ef_register.bold) == "\x1b[1mBold Text\x1b[0m"

def test_italic_effect(ef_register):
    assert str(ef_register.i) == "\x1b[3mItalic Text\x1b[0m"
    assert str(ef_register.italic) == "\x1b[3mItalic Text\x1b[0m"

def test_underline_effect(ef_register):
    assert str(ef_register.u) == "\x1b[4mUnderlined Text\x1b[0m"
    assert str(ef_register.underl) == "\x1b[4mUnderlined Text\x1b[0m"

def test_blink_effect(ef_register):
    assert str(ef_register.blink) == "\x1b[5mBlinking Text\x1b[0m"

def test_inverse_effect(ef_register):
    assert str(ef_register.inverse) == "\x1b[7mInverse Text\x1b[0m"

def test_hidden_effect(ef_register):
    assert str(ef_register.hidden) == "\x1b[8mHidden Text\x1b[0m"

def test_strike_through_effect(ef_register):
    assert str(ef_register.strike) == "\x1b[9mStrike-Through Text\x1b[0m"

def test_reset_all_effects(ef_register):
    combined_effect = f"{ef_register.bold}{ef_register.italic}Bold and Italic Text{ef_register.rs}"
    assert str(combined_effect) == "\x1b[1m\x1b[3mBold and Italic Text\x1b[0m"
