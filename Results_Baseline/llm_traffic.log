    namedtuple_repr = reg.as_namedtuple()
    assert isinstance(namedtuple_repr, tuple)
    assert namedtuple_repr == ('Register', (), {'renderfuncs': {}, 'is_muted': False, 'eightbit_call': <lambda>, 'rgb_call': <lambda>})
