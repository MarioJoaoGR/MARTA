class RenderType:
    def __init__(self, name: str, render_method: callable):
        """
        Initializes a new RenderType instance.
        
        :param name: A string representing the type of rendering (e.g., "OpenGL", "DirectX").
        :param render_method: A callable that implements the specific rendering method for this type.
        """
