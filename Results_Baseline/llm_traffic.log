    assert reg.renderfuncs['custom']("function") == "Custom function", "The set render function should work correctly."

def test_copy():
    reg = Register()
    copied_reg = reg.copy()
    assert isinstance(copied_reg, Register), "The copy method should return a deepcopy of the current register object."
    assert reg is not copied_reg, "The copies should be different objects."
    assert reg.renderfuncs == copied_reg.renderfuncs, "The copy method should create a deepcopy of renderfuncs."
    assert reg.is_muted == copied_reg.is_muted, "The copy method should create a deepcopy of is_muted."
    assert reg.eightbit_call == copied_reg.eightbit_call, "The copy method should create a deepcopy of eightbit_call."
    assert reg.rgb_call == copied_reg.rgb_call, "The copy method should create a deepcopy of rgb_call."

def test_set_lambda_functions():
    reg = Register()
    reg.set_eightbit_call(lambda x: x)
    reg.set_rgb_call(lambda r, g, b: (r, g, b))
    assert reg.eightbit_call("8-bit") == "8-bit", "The set eightbit_call should work correctly."
    assert reg.rgb_call(255, 0, 0) == (255, 0, 0), "The set rgb_call should work correctly."

def test_export_as_dict_namedtuple():
    reg = Register()
    dict_repr = reg.as_dict()
    namedtuple_repr = reg.as_namedtuple()
    assert isinstance(dict_repr, dict), "The as_dict method should return a dictionary."
    assert isinstance(namedtuple_repr, tuple), "The as_namedtuple method should return a named tuple."
