    custom_dict = {'is_muted': False, 'renderfuncs': {}, 'eightbit_call': lambda x: x, 'rgb_call': lambda r, g, b: (r, g, b)}
    reg = Register()
    reg.update_from_dict(custom_dict)
    assert not reg.is_muted

