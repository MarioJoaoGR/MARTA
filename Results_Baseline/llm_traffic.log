class StylingRule:
    pass  # Placeholder for actual StylingRule implementation

class Style(str):
    def __new__(cls, *rules: StylingRule, value: str = "") -> "Style":
        new_cls = super().__new__(cls, value)  # Inherit from str and set the initial value
        setattr(new_cls, "rules", rules)
        return new_cls

