    reg = Register()
    reg.is_muted = True  # Assuming the register is muted by default for this example
    reg.unmute()
    assert not reg.is_muted

# Test setting and getting a color
def test_set_and_get_color():
    reg = Register()
    reg.set_color(255, 0, 0)  # Setting red color
    assert reg.get_color() == (255, 0, 0)

# Test copying a register and ensuring it is a different instance
def test_copy():
    reg = Register()
    copied_register = reg.copy()
    assert not (copied_register is reg)
    assert copied_register.renderfuncs == {}
    assert not copied_register.is_muted
    assert copied_register.eightbit_call(1) == 1
    assert copied_register.rgb_call(255, 0, 0) == (255, 0, 0)

