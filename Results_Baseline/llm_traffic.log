import pytest
from primitive import Register

# Test creating a Register instance
def test_create_register():
    reg = Register()
    assert hasattr(reg, 'renderfuncs')
    assert isinstance(reg.renderfuncs, dict)
    assert hasattr(reg, 'is_muted')
    assert isinstance(reg.is_muted, bool)
    assert hasattr(reg, 'eightbit_call')
    assert callable(reg.eightbit_call)
    assert hasattr(reg, 'rgb_call')
    assert callable(reg.rgb_call)

# Test setting a custom render function
def test_set_custom_render_function():
    reg = Register()
    def custom_render(x):
        return f"Custom {x}"
    
    reg.renderfuncs['custom'] = custom_render
    assert callable(reg.renderfuncs['custom'])
    assert reg.renderfuncs['custom']("function") == "Custom function"

# Test muting the register
def test_mute():
    reg = Register()
    reg.mute()
    assert reg.is_muted is True

# Test unmuting the register
def test_unmute():
    reg = Register()
    reg.mute()
    reg.unmute()
    assert reg.is_muted is False

# Test setting a specific RGB color
def test_set_color():
    reg = Register()
    reg.set_color(255, 0, 0)  # Red color
    assert reg.get_color() == (255, 0, 0)

# Test exporting the register as a dictionary
def test_as_dict():
    reg = Register()
    reg_dict = reg.as_dict()
    assert isinstance(reg_dict, dict)
    assert 'renderfuncs' in reg_dict
    assert 'is_muted' in reg_dict
    assert 'eightbit_call' in reg_dict
    assert 'rgb_call' in reg_dict

# Test creating a deep copy of the register
def test_copy():
    reg = Register()
    copied_reg = reg.copy()
    assert copied_reg is not reg

# Test setting custom lambda functions for color handling
def test_set_custom_lambda_functions():
    reg = Register()
    def eightbit_call(x):
        return f"EightBit {x}"
    
    def rgb_call(r, g, b):
        return (r, g, b)
    
    reg.set_eightbit_call(eightbit_call)
    reg.set_rgb_call(rgb_call)
    assert reg.eightbit_call("value") == "EightBit value"
    assert reg.rgb_call(255, 0, 0) == (255, 0, 0)

# Test updating the register from a dictionary
def test_update_from_dict():
    reg = Register()
    update_dict = {'is_muted': False, 'renderfuncs': {}}
    reg.update_from_dict(update_dict)
    assert not reg.is_muted

# Test converting the register to a named tuple
def test_as_namedtuple():
    reg = Register()
    namedtuple_repr = reg.as_namedtuple()
    assert isinstance(namedtuple_repr, tuple)
