%%{init: {'theme': 'base', 'themeVariables': { 'mainBkg': '#ffffff', 'primaryColor': '#fff', 'primaryBorderColor': '#000', 'edgeLabelBackground':'#fff', 'tertiaryColor': '#fff', 'lineColor': '#000', 'textColor': '#000'}}}%%
flowchart TD
    Start(("Start"))

    %% --- PHASE 1: KNOWLEDGE & INFERENCE ---
    subgraph Phase1 ["Phase 1: Context Building & Type Inference (TEST4PY)"]
        direction TB
        Spacer1[ ]:::void
        Spacer1 ~~~ Source[/"Target Python Project"/]

        subgraph KB ["1. Knowledge Base Construction"]
            direction TB
            PyCG["PyCG Static Analysis"]
            CG[/"Call Graph<br/>(Traversal Guide)"/]
            FuncSumm["LLM: Function Summaries<br/>(Reads: Source + Caller/Callee Context)"]
            
            ASTClass["AST Analysis<br/>(Class Parser)"]
            ClassMembers[/"Class Members<br/>(Defined & Inherited)"/]
            
            ClassSumm["LLM: Class Summaries<br/>(Reads: Func Summaries + Class Members)"]
            DB[("Vector DB (Chroma)<br/>Stores Class Embeddings")]

            PyCG --> CG --> FuncSumm
            ASTClass --> ClassMembers
            
            FuncSumm --> ClassSumm
            ClassMembers --> ClassSumm
            ClassSumm --> DB
        end

        subgraph Inference ["2. Parameter Type Inference"]
            direction TB
            ASTFunc["AST Analysis<br/>(Reads target function body)"]
            Extracted[/"Accessed Members List<br/>(e.g., param.login())"/]

            SynFilter["Syntactic Filtering<br/>(Queries DB for classes with matching members)"]
            Candidates[/"Filtered Candidate Types"/]

            Ambig{"Ambiguity?<br/>(> 1 Candidate)"}

            SemRetrieval["Semantic Retrieval (LLM + MMR)<br/>(Scores behavioral intent)"]

            ASTFunc --> Extracted --> SynFilter --> Candidates --> Ambig
            Ambig -- "Yes" --> SemRetrieval
        end

        Source --> PyCG
        Source --> ASTClass
        Source --> ASTFunc
        
        DB -. "RAG Query" .-> SynFilter
        SemRetrieval --> Context
        Ambig -- "No" --> Context

        Context[/"Rich Type Context<br/>(Source, Inferred Types & Docstring Summary)"/]
    end

    Start --> Source

    %% --- GLOBAL SPLIT ---
    Context --> Split{"Generation Strategy?"}

    %% --- LEFT BRANCH: BASELINE ---
    subgraph Baseline ["BASELINE (Original Test4Py)"]
        direction TB
        SpacerBase[ ]:::void
        GenBase["One-Shot LLM Prompt<br/>(Feeds Context + Source)"]
        SpacerBase ~~~ GenBase

        ExecBase["Pytest Execution<br/>(subprocess.run)"]
        CheckBase{"Passed?"}

        GenBase --> ExecBase --> CheckBase

        CheckBase -- "Yes" --> SaveBase["✅ Success"]

        CheckBase -- "No" --> RepairBase["Adaptive Repair<br/>(Sends Error Trace to LLM)"]
        RepairBase --> RetryCheck{"Attempts < N?"}
        RetryCheck -- "Yes" --> ExecBase
        RetryCheck -- "No" --> FailBase["❌ Give Up<br/>(Removes asserts for stubbing)<br/>(Moves file to /test_quarantine with report)"]
    end

    %% --- RIGHT BRANCH: REACT ---
    subgraph ReAct ["CONTRIBUTION (ReAct Agents)"]
        direction TB
        SpacerReact[ ]:::void
        Planner["🕵️ PLANNER Agent<br/>(Analyzes Rich Context -> Identifies Test Cases)"]
        SpacerReact ~~~ Planner

        JSON[/"Test Plan JSON Array<br/>(Happy Path, Edge Cases, Errors)"/]

        Assertion["👷 ASSERTION Agent<br/>(Translates JSON Scenario to Pytest Code)"]
        ExecReact["Pylint & Pytest Execution<br/>(subprocess.run)"]
        CheckReact{"Passed?"}

        Planner --> JSON --> Assertion --> ExecReact --> CheckReact

        CheckReact -- "Yes" --> SaveReact["✅ Success"]

        CheckReact -- "No" --> Reason["🧠 Self-Healing<br/>(Reads Error Trace -> Rewrites Pytest Code)"]
        Reason --> CheckRetryReact{"Attempts < N?"}

        CheckRetryReact -- "Yes" --> Assertion
        CheckRetryReact -- "No" --> FailReact["❌ Give Up<br/>(Moves file to /test_quarantine with report)"]
    end

    %% Global connections
    Split -- "Single Prompt" --> GenBase
    Split -- "Multi-Agent" --> Planner

    %% --- STYLES ---
    classDef void width:0px,height:0px,fill:none,stroke:none;
    style Split fill:#fff,stroke:#333,stroke-width:4px
    style Phase1 fill:#f9f9f9,stroke:#666,stroke-dasharray: 5 5
    style KB fill:#ececec,stroke:#aaa,stroke-width:1px
    style Inference fill:#ececec,stroke:#aaa,stroke-width:1px
    style Context fill:#eef,stroke:#333,stroke-width:2px
    style Planner fill:#eef,stroke:#333,stroke-width:2px
    style Reason fill:#eef,stroke:#333,stroke-width:2px
    style DB fill:#fff,stroke:#333,stroke-width:1px